{
    "manifest_version": 3,
    "name": "LabGuard Monitor",
    "version": "1.0",
    "description": "Educational monitoring extension to track search queries and website usage.",
    "permissions": [
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}