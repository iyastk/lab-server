<Window x:Class="ClientLocker.UserDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LabGuard Dashboard" 
        Height="600" Width="300"
        WindowStyle="None" 
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Left="10" Top="10"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="#CC0F172A" CornerRadius="15" BorderBrush="#334155" BorderThickness="1" Margin="5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="LabGuard" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="UserTitle" Text="Logged in as: ..." Foreground="#94a3b8" FontSize="12"/>
            </StackPanel>

            <!-- Quotas -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <Border Background="#1e293b" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Daily Remaining" Foreground="#94a3b8" FontSize="11"/>
                        <TextBlock x:Name="DailyText" Text="00:00:00" Foreground="#22c55e" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#1e293b" CornerRadius="10" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Weekly Remaining" Foreground="#94a3b8" FontSize="11"/>
                        <TextBlock x:Name="WeeklyText" Text="00:00:00" Foreground="#3b82f6" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Actions / Info -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Quick Actions" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <Button x:Name="ChangePassBtn" Content="Change Password" Click="ChangePass_Click" 
                        Background="#334155" Foreground="White" Padding="10" Margin="0,0,0,5" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="ShowLogsBtn" Content="View Activity" Click="ViewLogs_Click" 
                        Background="#334155" Foreground="White" Padding="10" Margin="0,0,0,5" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="ShareFileBtn" Content="Share File with Peer" Click="ShareFile_Click" 
                        Background="#0ea5e9" Foreground="White" Padding="10" Margin="0,0,0,5" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="RequestTimeBtn" Content="Request Extra Time" Click="RequestTime_Click" 
                        Background="#4f46e5" Foreground="White" Padding="10" Margin="0,0,0,5" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- Session Controls -->
            <Button Grid.Row="3" Content="Logout &amp; Lock PC" Click="Logout_Click" 
                    Background="#ef4444" Foreground="White" FontWeight="Bold" Padding="15" Margin="0,0,0,10" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
            
            <TextBlock Grid.Row="4" Text="PC: STATION-01" Foreground="#475569" HorizontalAlignment="Center" FontSize="10" x:Name="PcNameText"/>
        </Grid>
    </Border>
</Window>
